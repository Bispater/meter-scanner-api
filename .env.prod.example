# Django Settings
SECRET_KEY=change-this-to-a-secure-random-secret-key-in-production
DEBUG=False
ALLOWED_HOSTS=scan-service.favric.cl,localhost,127.0.0.1

# CORS Settings (origins separados por coma, sin espacios)
# Incluye los dominios del panel en producción. Si desarrollas el admin en local pero la API está en prod, añade:
#   http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOWED_ORIGINS=https://meterscan-admin.web.app,https://meterscan-admin.favric.cl,https://scan-service.favric.cl,http://localhost:4200,http://127.0.0.1:4200

# Database Settings
DB_NAME=hydroscan
DB_USER=hydroscan
DB_PASSWORD=change-this-secure-password-in-production

# Gemini AI (OCR)
GEMINI_API_KEY=your-gemini-api-key-here

# API Port
API_PORT=8001
